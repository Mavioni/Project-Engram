# ─────────────────────────────────────────────────────────────
# Engram — environment variables
# Copy this file to `.env` for local dev. Set the same vars in
# Netlify (Site settings → Environment variables) for prod.
#
# Engram is LOCAL-FIRST: none of these are required to run the app.
# Leave any block blank and its feature stays disabled gracefully.
# ─────────────────────────────────────────────────────────────

# ── Supabase (auth + cloud sync) ──
# Create a project at https://supabase.com, copy from Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Stripe (subscriptions) ──
# Publishable key is fine to ship. Create Products/Prices in Stripe
# Dashboard and paste the Price IDs here.
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_STRIPE_PRICE_MONTHLY=
VITE_STRIPE_PRICE_YEARLY=

# ── Anthropic / Claude ──
# These are ONLY read by the Supabase Edge Functions (server-side).
# Never expose this key to the browser. Set it with:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#
# Left here for reference only:
#   ANTHROPIC_API_KEY=
#   ANTHROPIC_MODEL=claude-sonnet-4-6
#   STRIPE_SECRET_KEY=
#   STRIPE_WEBHOOK_SECRET=
